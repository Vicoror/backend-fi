generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(uuid())
  folio         String       @unique
  email         String       @unique
  password      String
  role          Role
  status        UserStatus   @default(INACTIVE)
  createdAt     DateTime     @default(now())
  coursesTaught Course[]     @relation("TeacherCourses")
  enrollments   Enrollment[]
  payments      Payment[]
  profile       Profile?
  purchases     Purchase[]
  entregasTarea   EntregaTarea[]        // Cambiado de tareas a entregasTarea
  calificacionesExamen CalificacionExamen[]  // Cambiado de examenes a calificacionesExamen
  estadisticasTareas EstadisticasTareas[]
}

model Profile {
  id              String  @id @default(uuid())
  userId          String  @unique
  nombre          String
  apellidoPaterno String
  apellidoMaterno String?
  telefono        String?
  estado          Estado?
  user            User    @relation(fields: [userId], references: [id])
}

model Course {
  id               String       @id @default(uuid())
  code             String       @unique
  nivel            String
  subnivel         String?
  cupoMaximo       Int
  alumnosInscritos Int          @default(0)
  precio           Int
  horario          String
  dias             String
  duracion         String
  teacherId        String?
  createdAt        DateTime     @default(now())
  activo           Boolean      @default(true)
  fin              DateTime
  inicio           DateTime
  calendarioPdf    String?
  urlCurso         String?
  teacher          User?        @relation("TeacherCourses", fields: [teacherId], references: [id])
  enrollments      Enrollment[]
  purchases        Purchase[]
   tareas           Tarea[]              // Relación con tareas
  examenes         Examen[]             // Relación con exámenes
}

model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
}

model Purchase {
  id              String      @id @default(uuid())
  userId          String
  courseId        String
  paymentType     PaymentType
  refunded        Boolean     @default(false)
  stripeSessionId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  status          String      @default("COMPLETED")
  course          Course      @relation(fields: [courseId], references: [id])
  user            User        @relation(fields: [userId], references: [id])
}

model Payment {
  id              String   @id @default(uuid())
  userId          String
  stripeSessionId String   @unique
  stripePaymentId String?
  amount          Int
  currency        String
  status          String
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String
  codigo    String
  expiraEn  DateTime
  usado     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, codigo])
  @@index([email])
  @@index([expiraEn])
}

model Aspirante {
  id        String   @id @default(uuid())
  email     String   @db.VarChar(50)
  horario1  String
  horario2  String
  nivel     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([nivel])
}

model CarruselItem {
  id          String   @id @default(cuid())
  titulo      String
  tipo        TipoMedia // "IMAGEN" o "VIDEO"
  url         String   // URL de Cloudinary
  orden       Int      // 1-5 para secuencia
  link        String?  // URL opcional para redirección
  fechaInicio DateTime
  fechaFin    DateTime
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([orden])
  @@index([activo])
  @@index([fechaInicio, fechaFin])
}

model ClaseMuestra {
  id            String   @id @default(cuid())
  correo        String   @unique
  tipoCurso     String   // 'Individuales' | 'Grupales'
  nivel         String   // 'A1', 'A1+', 'A2', 'A2+', 'B1', 'B1+', 'B2'
  diaPreferido  DateTime // Fecha preferida para la clase muestra
  horario       String   // '07:00', '08:00', etc.
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("clase_muestra")
}

model Temario {
  id            String   @id @default(cuid())
  nivel         String  @unique 
  tituloGeneral String

  temas         Tema[]
}

model Tema {
  id        String   @id @default(cuid())
  temarioId String

  titulo    String   // Ej: Les adjectifs
  material  String?  // PDF o link principal
  orden     Int

  temario   Temario  @relation(fields: [temarioId], references: [id], onDelete: Cascade)
  subtemas  Subtema[]
}

model Subtema {
  id       String   @id @default(cuid())
  temaId   String

  tipo     TipoSubtema
  titulo   String
  material String
  orden    Int

  tema     Tema     @relation(fields: [temaId], references: [id], onDelete: Cascade)
}

// Tareas por nivel (no por usuario)
model Tarea {
  id            String      @id @default(uuid())
  nivel         String      // Nivel al que pertenece (A1, A2, B1, etc.)
  tipo          TipoTarea
  titulo        String      // Título descriptivo
  descripcion   String?     // Descripción opcional
  tarea         String      // URL o ruta del archivo
  fechaLimite   DateTime
  activo        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  // Relaciones
  entregas      EntregaTarea[]
  course        Course?     @relation(fields: [courseId], references: [id])
  courseId      String?
  
  @@index([nivel])
  @@index([activo])
}

// Registro de tareas realizadas por cada alumno
model EntregaTarea {
  id            String   @id @default(uuid())
  tareaId       String
  userId        String
  realizada     Boolean  @default(false)
  fechaEntrega  DateTime?
  calificacion  Float?   // Calificación opcional de la tarea
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relaciones
  tarea         Tarea    @relation(fields: [tareaId], references: [id])
  user          User     @relation(fields: [userId], references: [id])
  
  @@unique([tareaId, userId])  // Un alumno solo puede entregar una vez cada tarea
  @@index([tareaId])
  @@index([userId])
  @@index([realizada])
}

// Exámenes por nivel (no por usuario)
model Examen {
  id            String      @id @default(uuid())
  nivel         String
  titulo        String
  descripcion   String?
  examen        String      // URL o ruta del archivo
  fechaLimite   DateTime?
  activo        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  // Relaciones
  calificaciones CalificacionExamen[]
  course        Course?     @relation(fields: [courseId], references: [id])
  courseId      String?
  
  @@index([nivel])
  @@index([activo])
}

// Calificaciones por alumno para cada examen
model CalificacionExamen {
  id            String   @id @default(uuid())
  examenId      String
  userId        String
  calificacion  Float?
  entregado     Boolean  @default(false)
  fechaEntrega  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relaciones
  examen        Examen   @relation(fields: [examenId], references: [id])
  user          User     @relation(fields: [userId], references: [id])
  
  @@unique([examenId, userId])  // Un alumno solo puede tener una calificación por examen
  @@index([examenId])
  @@index([userId])
}

// Estadísticas de tareas por alumno y nivel
model EstadisticasTareas {
  id                    String   @id @default(uuid())
  userId                String
  nivel                 String
  totalTareas           Int      @default(0)
  tareasRealizadas      Int      @default(0)
  ultimaActualizacion   DateTime @default(now())
  
  user                  User     @relation(fields: [userId], references: [id])
  
  @@unique([userId, nivel])
  @@index([userId])
}

enum TipoTarea {
  Grammaire
  ProductionOrale
  ProductionEcrite
  ComprehensionOrale
  ComprehensionEcrite
  Vocabulaire
  Varios
}

enum TipoSubtema {
  EJERCICIO
  VOCABULARIO
}

enum TipoMedia {
  IMAGEN
  VIDEO
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum PaymentType {
  CARD
  OXXO
}

enum Estado {
  AGUASCALIENTES
  BAJA_CALIFORNIA
  BAJA_CALIFORNIA_SUR
  CAMPECHE
  CHIAPAS
  CHIHUAHUA
  CIUDAD_DE_MEXICO
  COAHUILA
  COLIMA
  DURANGO
  ESTADO_DE_MEXICO
  GUANAJUATO
  GUERRERO
  HIDALGO
  JALISCO
  MICHOACAN
  MORELOS
  NAYARIT
  NUEVO_LEON
  OAXACA
  PUEBLA
  QUERETARO
  QUINTANA_ROO
  SAN_LUIS_POTOSI
  SINALOA
  SONORA
  TABASCO
  TAMAULIPAS
  TLAXCALA
  VERACRUZ
  YUCATAN
  ZACATECAS
}
